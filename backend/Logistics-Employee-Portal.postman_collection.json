        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "  pm.collectionVariables.set('token', jsonData.token);",
                  "}",
                  "if (jsonData.user && jsonData.user._id) {",
                  "  pm.collectionVariables.set('userId', jsonData.user._id);",
                  "}"
                ]
